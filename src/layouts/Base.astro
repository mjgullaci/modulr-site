---
import '../styles/global.css';
import Icons from '../components/Icons.astro';
import Loader from '../components/Loader.astro';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import settings from '../data/settings.json';
const seo = settings.seo;
const sq = settings.square || {};
const sqSdk = sq.env === 'production' ? 'https://web.squarecdn.com/v1/square.js' : 'https://sandbox.web.squarecdn.com/v1/square.js';
const { title = seo.title, description = seo.description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={seo.ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&display=swap" rel="stylesheet" />
  {sq.appId && <script type="application/json" id="sq-config" set:html={JSON.stringify({ appId: sq.appId, locationId: sq.locationId, currency: sq.currency || 'AUD', env: sq.env || 'sandbox' })}></script>}
  {sq.appId && <script src={sqSdk} is:inline></script>}
</head>
<body>
  <Icons />
  <Loader />
  <Header />
  <MobileMenu />
  <main id="top">
    <slot />
  </main>
  <Footer />

  <div class="modal" id="ticketModal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-label="Buy tickets">
      <button class="modal-x" type="button" data-close aria-label="Close">&times;</button>
      <div id="tkForm">
      <p class="modal-eyebrow">Tickets</p>
      <h3 class="modal-title" id="tkVenue">Venue</h3>
      <p class="modal-sub"><span id="tkDate"></span> &middot; <span id="tkCity"></span></p>
      <p class="modal-addr" id="tkAddr"></p>
      <p class="modal-note">Secure checkout stays right here on the site, powered by Square.</p>
      <p class="tk-amount" id="tkAmount"></p>
      <div class="tk-fields" id="tkFields">
        <input id="tkFirst" type="text" placeholder="First name" autocomplete="given-name" />
        <input id="tkLast" type="text" placeholder="Last name" autocomplete="family-name" />
        <input id="tkEmail" type="email" placeholder="Email" autocomplete="email" />
      </div>
      <div id="card-container" class="card-box"></div>
      <button id="tkPayBtn" class="btn btn-solid modal-cta" type="button">Pay now</button>
      <p id="tkStatus" class="tk-status" role="status" aria-live="polite"></p>
      <a id="tkExternal" class="tk-alt" href="#" target="_blank" rel="noopener" style="display:none">Tickets via venue</a>
      </div>
      <div class="tk-done" id="tkDone" hidden>
        <p class="modal-eyebrow">Confirmed</p>
        <h3 class="modal-title">You&#39;re in</h3>
        <p class="tk-done-num" id="tkDoneNum"></p>
        <p class="tk-done-msg" id="tkDoneMsg">Check your email for your ticket. See you on the floor.</p>
        <button class="btn btn-solid modal-cta" type="button" data-close>Done</button>
      </div>
    </div>
  </div>

  <div class="modal" id="productModal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-label="Buy product">
      <button class="modal-x" type="button" data-close aria-label="Close">&times;</button>
      <div class="pm-grid">
        <div class="pm-art"><img id="pmImg" src="" alt="" /></div>
        <div class="pm-info">
          <h3 class="modal-title" id="pmName">Product</h3>
          <span class="price" id="pmPrice"></span>
          <p class="modal-label">Size</p>
          <div class="sizes" id="pmSizes"></div>
          <div class="pm-fields" id="pmFields">
            <input id="pmBuyerFirst" type="text" placeholder="First name" autocomplete="given-name" />
            <input id="pmBuyerLast" type="text" placeholder="Last name" autocomplete="family-name" />
            <input id="pmBuyerEmail" type="email" placeholder="Email" autocomplete="email" />
            <textarea id="pmBuyerAddr" rows="2" placeholder="Shipping address (street, suburb, state, postcode)"></textarea>
          </div>
          <div id="pm-card-container" class="card-box"></div>
          <button class="btn btn-solid modal-cta" id="pmBuy" type="button" disabled>Select a size</button>
          <p id="pmStatus" class="tk-status" role="status" aria-live="polite"></p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      if(location.protocol==='http:'){ location.replace('https://'+location.host+location.pathname+location.search+location.hash); return; }
      var loader=document.getElementById('loader'), vid=document.getElementById('loaderVid'), closed=false;
      function closeLoader(){ if(closed)return; closed=true; loader.classList.add('is-done'); setTimeout(function(){loader.remove();},900); }
      if(loader&&vid){ vid.addEventListener('ended',closeLoader); vid.addEventListener('error',closeLoader); loader.addEventListener('click',closeLoader); setTimeout(closeLoader,5000); if(window.matchMedia('(prefers-reduced-motion: reduce)').matches){setTimeout(closeLoader,300);} var started=false; function reveal(){ if(!started){ started=true; loader.classList.add('vid-live'); } } vid.addEventListener('playing',function(){ if(vid.currentTime>0) reveal(); }); vid.addEventListener('timeupdate',function(){ if(vid.currentTime>0.05) reveal(); }); function bail(){ if(!closed && !started) closeLoader(); } try{ var p=vid.play&&vid.play(); if(p&&p.catch){ p.catch(function(){ closeLoader(); }); } }catch(e){ closeLoader(); } setTimeout(bail,650); }

      var header=document.getElementById('siteHeader');
      var themed=document.querySelectorAll('main [data-theme], footer[data-theme]');
      function syncHeader(){ if(!header)return; var probe=header.offsetHeight-1, cur='dark'; for(var i=0;i<themed.length;i++){var r=themed[i].getBoundingClientRect(); if(r.top<=probe&&r.bottom>probe){cur=themed[i].getAttribute('data-theme');break;}} header.classList.toggle('t-dark',cur==='dark'); header.classList.toggle('t-light',cur==='light'); }
      document.addEventListener('scroll',syncHeader,{passive:true}); window.addEventListener('resize',syncHeader); syncHeader();

      var burger=document.getElementById('burger'), menu=document.getElementById('menu');
      function setMenu(o){ menu.classList.toggle('open',o); document.body.classList.toggle('menu-open',o); }
      if(burger&&menu){ burger.addEventListener('click',function(){setMenu(!menu.classList.contains('open'));}); menu.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});}); }

      var form=document.getElementById('signupForm');
      if(form){ form.addEventListener('submit',async function(e){ e.preventDefault();
        var input=form.querySelector('input[type=email]'), btn=form.querySelector('button');
        var email=(input&&input.value||'').trim(); if(email.indexOf('@')<1) return;
        if(btn) btn.disabled=true;
        try{
          var r=await fetch('/api/subscribe',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ email:email }) });
          var d=await r.json();
          if(r.ok&&d.ok){ form.classList.add('sent'); }
          else { var msg=form.querySelector('.sent-msg'); if(msg) msg.textContent=(d&&d.error)?d.error:'Could not sign you up, please try again.'; form.classList.add('sent'); }
        }catch(e){ form.classList.add('sent'); }
      }); }

      var mqEl=document.querySelector('.marquee');
      var mqLine=mqEl&&mqEl.querySelector('.marquee-line');
      if(mqEl&&mqLine&&!window.matchMedia('(prefers-reduced-motion: reduce)').matches){
        var mqHalf=0, mqLast=0, mqSpeed=0, mqPos=0;
        function mqMeasure(){ mqHalf=mqLine.scrollWidth/2; mqSpeed=mqHalf/15; }
        mqMeasure(); window.addEventListener('resize', mqMeasure);
        function mqStep(ts){ if(!mqLast) mqLast=ts; var dt=(ts-mqLast)/1000; mqLast=ts; if(dt>0.1) dt=0.1; if(mqHalf>0){ mqPos+=mqSpeed*dt; if(mqPos>=mqHalf) mqPos-=mqHalf; mqEl.scrollLeft=mqPos; } requestAnimationFrame(mqStep); }
        requestAnimationFrame(mqStep);
      }

      function openModal(m){ m.classList.add('open'); m.setAttribute('aria-hidden','false'); document.body.classList.add('menu-open'); }
      function closeModal(m){ m.classList.remove('open'); m.setAttribute('aria-hidden','true'); document.body.classList.remove('menu-open'); }
      document.querySelectorAll('.modal [data-close]').forEach(function(el){ el.addEventListener('click',function(){ closeModal(el.closest('.modal')); }); });
      document.addEventListener('keydown',function(e){ if(e.key==='Escape'){ document.querySelectorAll('.modal.open').forEach(closeModal); } });

      var ticketModal=document.getElementById('ticketModal');
      var sqCfg=null; try{ var cfgEl=document.getElementById('sq-config'); if(cfgEl) sqCfg=JSON.parse(cfgEl.textContent); }catch(e){}
      var CUR=(sqCfg&&sqCfg.currency)||'AUD';
      var sqPayments=null;
      function ensurePayments(){ if(!sqPayments&&sqCfg&&window.Square){ try{ sqPayments=window.Square.payments(sqCfg.appId, sqCfg.locationId); }catch(e){ sqPayments=null; } } return sqPayments; }
      function money(n,c){ try{ return new Intl.NumberFormat(undefined,{style:'currency',currency:c||'AUD'}).format(n); }catch(e){ return (c||'AUD')+' '+n.toFixed(2); } }

      var tkCard=null, tkReady=false, tkAmt=0, tkLabel='', tkVenueVal='', tkCityVal='', tkDateVal='', tkDoorsVal='', tkAddrVal='';
      async function initTicketCard(){ if(tkReady) return; var p=ensurePayments(); if(!p) return; try{ tkCard=await p.card(); await tkCard.attach('#card-container'); tkReady=true; }catch(e){ var s=document.getElementById('tkStatus'); if(s) s.textContent='Card form could not load.'; } }
      document.querySelectorAll('.ticket-btn').forEach(function(b){ b.addEventListener('click',function(){
        document.getElementById('tkVenue').textContent=b.getAttribute('data-venue')||'Show';
        document.getElementById('tkDate').textContent=b.getAttribute('data-date')||'';
        document.getElementById('tkCity').textContent=b.getAttribute('data-city')||'';
        tkLabel=b.getAttribute('data-venue')||'Show';
        tkVenueVal=tkLabel; tkCityVal=b.getAttribute('data-city')||''; tkDateVal=b.getAttribute('data-date')||''; tkDoorsVal=b.getAttribute('data-doors')||''; tkAddrVal=b.getAttribute('data-address')||'';
        document.getElementById('tkAddr').textContent=tkAddrVal;
        document.getElementById('tkForm').style.display=''; document.getElementById('tkDone').hidden=true; document.getElementById('tkPayBtn').style.display='';
        tkAmt=parseFloat(b.getAttribute('data-amount')||'')||0;
        var amtEl=document.getElementById('tkAmount'), payBtn=document.getElementById('tkPayBtn'), st=document.getElementById('tkStatus'), cardBox=document.getElementById('card-container');
        st.textContent='';
        var url=b.getAttribute('data-url')||'#', ext=document.getElementById('tkExternal');
        if(url&&url!=='#'){ ext.href=url; ext.style.display=''; } else { ext.style.display='none'; }
        openModal(ticketModal);
        if(sqCfg && tkAmt>0){ amtEl.textContent=money(tkAmt,CUR)+' per ticket'; payBtn.style.display=''; cardBox.style.display=''; payBtn.disabled=false; initTicketCard(); }
        else { amtEl.textContent=''; payBtn.style.display='none'; cardBox.style.display='none'; if(!sqCfg) st.textContent='Checkout is being switched on. Use the venue link below for now.'; }
      });});
      var tkPayBtn=document.getElementById('tkPayBtn');
      if(tkPayBtn){ tkPayBtn.addEventListener('click',async function(){
        if(!tkReady||!tkCard) return;
        var st=document.getElementById('tkStatus');
        var fn=(document.getElementById('tkFirst').value||'').trim();
        var ln=(document.getElementById('tkLast').value||'').trim();
        var em=(document.getElementById('tkEmail').value||'').trim();
        if(!fn||!ln||em.indexOf('@')<1){ st.textContent='Please add your first name, last name and email.'; return; }
        tkPayBtn.disabled=true; st.textContent='Processing...';
        try{
          var res=await tkCard.tokenize();
          if(res.status!=='OK'){ st.textContent=(res.errors&&res.errors[0]&&res.errors[0].message)?res.errors[0].message:'Please check your card details.'; tkPayBtn.disabled=false; return; }
          var r=await fetch('/api/pay',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sourceId:res.token, amount:Math.round(tkAmt*100), currency:CUR, note:'Ticket: '+tkLabel+' | '+fn+' '+ln, buyerEmail:em, buyerName:fn+' '+ln, kind:'ticket', event:{ venue:tkVenueVal, city:tkCityVal, date:tkDateVal, doors:tkDoorsVal, address:tkAddrVal } }) });
          var data=await r.json();
          if(r.ok&&data.ok){ var num=data.ticketNo||''; var dn=document.getElementById('tkDoneNum'); if(dn) dn.textContent = num ? ('Ticket '+num) : ''; var dm=document.getElementById('tkDoneMsg'); if(dm) dm.textContent = data.emailed ? ('Check your email at '+em+' for your ticket. See you on the floor.') : ('Your ticket number is '+num+'. See you on the floor.'); var tf=document.getElementById('tkForm'); if(tf) tf.style.display='none'; var td=document.getElementById('tkDone'); if(td) td.hidden=false; }
          else { st.textContent=(data&&data.error)?data.error:'Payment failed. Please try again.'; tkPayBtn.disabled=false; }
        }catch(e){ st.textContent='Something went wrong. Please try again.'; tkPayBtn.disabled=false; }
      }); }

      var productModal=document.getElementById('productModal'), pmBuy=document.getElementById('pmBuy');
      var pmCard=null, pmReady=false, pmSize=null, pmAmt=0, pmName='';
      async function initStoreCard(){ if(pmReady) return; var p=ensurePayments(); if(!p) return; try{ pmCard=await p.card(); await pmCard.attach('#pm-card-container'); pmReady=true; }catch(e){ var s=document.getElementById('pmStatus'); if(s) s.textContent='Card form could not load.'; } }
      function pmRefreshBtn(){ if(!sqCfg||!(pmAmt>0)){ pmBuy.disabled=true; pmBuy.textContent='Coming soon'; return; } if(pmSize){ pmBuy.disabled=false; pmBuy.textContent='Pay '+money(pmAmt,CUR); } else { pmBuy.disabled=true; pmBuy.textContent='Select a size'; } }
      document.querySelectorAll('.buy-btn').forEach(function(b){ b.addEventListener('click',function(){
        pmName=b.getAttribute('data-name')||'Product';
        document.getElementById('pmName').textContent=pmName;
        pmAmt=parseFloat(b.getAttribute('data-price')||'')||0;
        document.getElementById('pmPrice').textContent=pmAmt>0?money(pmAmt,CUR):'Price on request';
        var img=document.getElementById('pmImg'); img.src=b.getAttribute('data-image')||''; img.alt=pmName;
        pmSize=null; document.getElementById('pmStatus').textContent='';
        var sizes=[]; try{sizes=JSON.parse(b.getAttribute('data-sizes'));}catch(e){sizes=['S','M','L','XL','XXL'];}
        var box=document.getElementById('pmSizes'); box.innerHTML='';
        sizes.forEach(function(sz){ var el=document.createElement('button'); el.type='button'; el.className='size'; el.textContent=sz;
          el.addEventListener('click',function(){ box.querySelectorAll('.size').forEach(function(x){x.classList.remove('sel');}); el.classList.add('sel'); pmSize=sz; pmRefreshBtn(); });
          box.appendChild(el); });
        var cardBox=document.getElementById('pm-card-container'), fields=document.getElementById('pmFields');
        if(sqCfg && pmAmt>0){ cardBox.style.display=''; if(fields) fields.style.display=''; pmBuy.style.display=''; initStoreCard(); }
        else { cardBox.style.display='none'; if(fields) fields.style.display='none'; }
        pmRefreshBtn();
        openModal(productModal);
      });});
      if(pmBuy){ pmBuy.addEventListener('click',async function(){
        if(!pmSize){ document.getElementById('pmStatus').textContent='Please choose a size.'; return; }
        if(!pmReady||!pmCard) return;
        var st=document.getElementById('pmStatus');
        var fn=(document.getElementById('pmBuyerFirst').value||'').trim();
        var ln=(document.getElementById('pmBuyerLast').value||'').trim();
        var em=(document.getElementById('pmBuyerEmail').value||'').trim();
        var ad=(document.getElementById('pmBuyerAddr').value||'').trim();
        if(!fn||!ln||em.indexOf('@')<1||!ad){ st.textContent='Please add your name, email and shipping address.'; return; }
        pmBuy.disabled=true; st.textContent='Processing...';
        try{
          var res=await pmCard.tokenize();
          if(res.status!=='OK'){ st.textContent=(res.errors&&res.errors[0]&&res.errors[0].message)?res.errors[0].message:'Please check your card details.'; pmBuy.disabled=false; return; }
          var note=pmName+' | size '+pmSize+' | '+fn+' '+ln+' | '+ad;
          var r=await fetch('/api/pay',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sourceId:res.token, amount:Math.round(pmAmt*100), currency:CUR, note:note, buyerEmail:em, buyerName:fn+' '+ln, kind:'merch', item:{ product:pmName, size:pmSize, address:ad } }) });
          var data=await r.json();
          if(r.ok&&data.ok){ st.textContent = data.emailed ? ('Order confirmed. '+(data.orderNo||'')+' emailed to '+em+'.') : ('Order confirmed'+(data.orderNo?(' '+data.orderNo):'')+'. The band will post it to your address.'); pmBuy.style.display='none'; }
          else { st.textContent=(data&&data.error)?data.error:'Payment failed. Please try again.'; pmBuy.disabled=false; }
        }catch(e){ st.textContent='Something went wrong. Please try again.'; pmBuy.disabled=false; }
      }); }
    })();
  </script>
</body>
</html>
