---
import '../styles/global.css';
import Icons from '../components/Icons.astro';
import Loader from '../components/Loader.astro';
import Header from '../components/Header.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import settings from '../data/settings.json';
const seo = settings.seo;
const sq = settings.square || {};
const sqSdk = sq.env === 'production' ? 'https://web.squarecdn.com/v1/square.js' : 'https://sandbox.web.squarecdn.com/v1/square.js';
const { title = seo.title, description = seo.description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={seo.ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&display=swap" rel="stylesheet" />
  {sq.appId && <script type="application/json" id="sq-config" set:html={JSON.stringify({ appId: sq.appId, locationId: sq.locationId, currency: sq.currency || 'AUD', env: sq.env || 'sandbox' })}></script>}
  {sq.appId && <script src={sqSdk} is:inline></script>}
</head>
<body>
  <Icons />
  <Loader />
  <Header />
  <MobileMenu />
  <main id="top">
    <slot />
  </main>
  <Footer />

  <div class="modal" id="ticketModal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-label="Buy tickets">
      <button class="modal-x" type="button" data-close aria-label="Close">&times;</button>
      <div id="tkForm">
      <p class="modal-eyebrow">Tickets</p>
      <h3 class="modal-title" id="tkVenue">Venue</h3>
      <p class="modal-sub"><span id="tkDate"></span> &middot; <span id="tkCity"></span></p>
      <p class="modal-addr" id="tkAddr"></p>
      <p class="modal-note">Secure checkout stays right here on the site, powered by Square.</p>
      <p class="tk-amount" id="tkAmount"></p>
      <div class="tk-qty" id="tkQtyRow">
        <span class="tk-qty-label">Number of tickets</span>
        <div class="tk-qty-ctrl">
          <button type="button" class="tk-qty-btn" id="tkQtyMinus" aria-label="Fewer tickets">&minus;</button>
          <span class="tk-qty-num" id="tkQtyVal">1</span>
          <button type="button" class="tk-qty-btn" id="tkQtyPlus" aria-label="More tickets">+</button>
        </div>
      </div>
      <p class="tk-total" id="tkTotal"></p>
      <p class="tk-left" id="tkLeft"></p>
      <div class="tk-fields" id="tkFields">
        <input id="tkFirst" type="text" placeholder="First name" autocomplete="given-name" />
        <input id="tkLast" type="text" placeholder="Last name" autocomplete="family-name" />
        <input id="tkEmail" type="email" placeholder="Email" autocomplete="email" />
      </div>
      <div id="card-container" class="card-box"></div>
      <button id="tkPayBtn" class="btn btn-solid modal-cta" type="button">Pay now</button>
      <p id="tkStatus" class="tk-status" role="status" aria-live="polite"></p>
      <a id="tkExternal" class="tk-alt" href="#" target="_blank" rel="noopener" style="display:none">Tickets via venue</a>
      </div>
      <div class="tk-done" id="tkDone" hidden>
        <p class="modal-eyebrow">Confirmed</p>
        <h3 class="modal-title">You&#39;re in</h3>
        <p class="tk-done-num" id="tkDoneNum"></p>
        <p class="tk-done-msg" id="tkDoneMsg">Check your email for your ticket. See you on the floor.</p>
        <button class="btn btn-solid modal-cta" type="button" data-close>Done</button>
      </div>
    </div>
  </div>

  <div class="modal" id="productModal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-label="Buy product">
      <button class="modal-x" type="button" data-close aria-label="Close">&times;</button>
      <div class="pm-grid">
        <div class="pm-art"><img id="pmImg" src="" alt="" /></div>
        <div class="pm-info">
          <h3 class="modal-title" id="pmName">Product</h3>
          <span class="price" id="pmPrice"></span>
          <p class="modal-label">Size</p>
          <div class="sizes" id="pmSizes"></div>
          <div class="tk-qty" id="pmQtyRow">
            <span class="tk-qty-label">Quantity</span>
            <div class="tk-qty-ctrl">
              <button type="button" class="tk-qty-btn" id="pmQtyMinus" aria-label="Fewer">&minus;</button>
              <span class="tk-qty-num" id="pmQtyVal">1</span>
              <button type="button" class="tk-qty-btn" id="pmQtyPlus" aria-label="More">+</button>
            </div>
          </div>
          <button class="btn btn-solid modal-cta" id="pmAdd" type="button" disabled>Select a size</button>
          <button class="cart-view-link" id="pmView" type="button" hidden>View cart</button>
          <p id="pmStatus" class="tk-status" role="status" aria-live="polite"></p>
        </div>
      </div>
    </div>
  </div>

  <div class="modal" id="cartModal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-label="Your cart">
      <button class="modal-x" type="button" data-close aria-label="Close">&times;</button>

      <div id="cartView">
        <p class="modal-eyebrow">Your cart</p>
        <h3 class="modal-title">Bag</h3>
        <p class="cart-empty" id="cartEmpty">Your cart is empty.</p>
        <div class="cart-lines" id="cartLines"></div>
        <div class="cart-summary" id="cartSummary" hidden>
          <span class="cart-summary-label">Subtotal</span>
          <span class="cart-summary-val" id="cartSubtotal"></span>
        </div>
        <button class="btn btn-solid modal-cta" id="cartCheckout" type="button" disabled>Checkout</button>
        <p class="cart-note" id="cartNote" hidden>Shipping across Australia. Secure checkout stays right here, powered by Square.</p>
      </div>

      <div id="checkoutView" hidden>
        <button type="button" class="cart-back" id="cartBack">&lsaquo; Back to cart</button>
        <p class="modal-eyebrow">Checkout</p>
        <div class="cart-mini" id="cartMini"></div>
        <p class="tk-total" id="coTotal"></p>
        <div class="tk-fields">
          <input id="coFirst" type="text" placeholder="First name" autocomplete="given-name" />
          <input id="coLast" type="text" placeholder="Last name" autocomplete="family-name" />
          <input id="coEmail" type="email" placeholder="Email" autocomplete="email" />
          <textarea id="coAddr" rows="2" placeholder="Shipping address (street, suburb, state, postcode)"></textarea>
        </div>
        <div id="cart-card-container" class="card-box"></div>
        <button class="btn btn-solid modal-cta" id="coPay" type="button">Pay</button>
        <p id="coStatus" class="tk-status" role="status" aria-live="polite"></p>
      </div>

      <div id="cartDone" hidden class="tk-done">
        <p class="modal-eyebrow">Confirmed</p>
        <h3 class="modal-title">Order confirmed</h3>
        <p class="tk-done-num" id="cartDoneNum"></p>
        <p class="tk-done-msg" id="cartDoneMsg">Check your email for your confirmation. Thanks for the support.</p>
        <button class="btn btn-solid modal-cta" type="button" data-close>Done</button>
      </div>

    </div>
  </div>

  <script is:inline>
    (function () {
      if(location.protocol==='http:'){ location.replace('https://'+location.host+location.pathname+location.search+location.hash); return; }
      var loader=document.getElementById('loader'), vid=document.getElementById('loaderVid'), closed=false;
      function closeLoader(){ if(closed)return; closed=true; loader.classList.add('is-done'); setTimeout(function(){loader.remove();},900); }
      if(loader&&vid){ vid.addEventListener('ended',closeLoader); vid.addEventListener('error',closeLoader); loader.addEventListener('click',closeLoader); setTimeout(closeLoader,5000); if(window.matchMedia('(prefers-reduced-motion: reduce)').matches){setTimeout(closeLoader,300);} var started=false; function reveal(){ if(!started){ started=true; loader.classList.add('vid-live'); } } vid.addEventListener('playing',function(){ if(vid.currentTime>0) reveal(); }); vid.addEventListener('timeupdate',function(){ if(vid.currentTime>0.05) reveal(); }); function bail(){ if(!closed && !started) closeLoader(); } try{ var p=vid.play&&vid.play(); if(p&&p.catch){ p.catch(function(){ closeLoader(); }); } }catch(e){ closeLoader(); } setTimeout(bail,650); }

      var header=document.getElementById('siteHeader');
      var themed=document.querySelectorAll('main [data-theme], footer[data-theme]');
      function syncHeader(){ if(!header)return; var probe=header.offsetHeight-1, cur='dark'; for(var i=0;i<themed.length;i++){var r=themed[i].getBoundingClientRect(); if(r.top<=probe&&r.bottom>probe){cur=themed[i].getAttribute('data-theme');break;}} header.classList.toggle('t-dark',cur==='dark'); header.classList.toggle('t-light',cur==='light'); }
      document.addEventListener('scroll',syncHeader,{passive:true}); window.addEventListener('resize',syncHeader); syncHeader();

      var burger=document.getElementById('burger'), menu=document.getElementById('menu');
      function setMenu(o){ menu.classList.toggle('open',o); document.body.classList.toggle('menu-open',o); }
      if(burger&&menu){ burger.addEventListener('click',function(){setMenu(!menu.classList.contains('open'));}); menu.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});}); }

      var form=document.getElementById('signupForm');
      if(form){ form.addEventListener('submit',async function(e){ e.preventDefault();
        var input=form.querySelector('input[type=email]'), btn=form.querySelector('button');
        var email=(input&&input.value||'').trim(); if(email.indexOf('@')<1) return;
        if(btn) btn.disabled=true;
        try{
          var r=await fetch('/api/subscribe',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ email:email }) });
          var d=await r.json();
          if(r.ok&&d.ok){ form.classList.add('sent'); }
          else { var msg=form.querySelector('.sent-msg'); if(msg) msg.textContent=(d&&d.error)?d.error:'Could not sign you up, please try again.'; form.classList.add('sent'); }
        }catch(e){ form.classList.add('sent'); }
      }); }

      var mqEl=document.querySelector('.marquee');
      var mqLine=mqEl&&mqEl.querySelector('.marquee-line');
      if(mqEl&&mqLine&&!window.matchMedia('(prefers-reduced-motion: reduce)').matches){
        var mqHalf=0, mqLast=0, mqSpeed=0, mqPos=0;
        function mqMeasure(){ mqHalf=mqLine.scrollWidth/2; mqSpeed=mqHalf/15; }
        mqMeasure(); window.addEventListener('resize', mqMeasure);
        function mqStep(ts){ if(!mqLast) mqLast=ts; var dt=(ts-mqLast)/1000; mqLast=ts; if(dt>0.1) dt=0.1; if(mqHalf>0){ mqPos+=mqSpeed*dt; if(mqPos>=mqHalf) mqPos-=mqHalf; mqEl.scrollLeft=mqPos; } requestAnimationFrame(mqStep); }
        requestAnimationFrame(mqStep);
      }

      function openModal(m){ m.classList.add('open'); m.setAttribute('aria-hidden','false'); document.body.classList.add('menu-open'); }
      function closeModal(m){ m.classList.remove('open'); m.setAttribute('aria-hidden','true'); document.body.classList.remove('menu-open'); }
      document.querySelectorAll('.modal [data-close]').forEach(function(el){ el.addEventListener('click',function(){ closeModal(el.closest('.modal')); }); });
      document.addEventListener('keydown',function(e){ if(e.key==='Escape'){ document.querySelectorAll('.modal.open').forEach(closeModal); } });

      var ticketModal=document.getElementById('ticketModal');
      var sqCfg=null; try{ var cfgEl=document.getElementById('sq-config'); if(cfgEl) sqCfg=JSON.parse(cfgEl.textContent); }catch(e){}
      var CUR=(sqCfg&&sqCfg.currency)||'AUD';
      var sqPayments=null;
      function ensurePayments(){ if(!sqPayments&&sqCfg&&window.Square){ try{ sqPayments=window.Square.payments(sqCfg.appId, sqCfg.locationId); }catch(e){ sqPayments=null; } } return sqPayments; }
      function money(n,c){ try{ return new Intl.NumberFormat(undefined,{style:'currency',currency:c||'AUD'}).format(n); }catch(e){ return (c||'AUD')+' '+n.toFixed(2); } }

      var ticketLeft={};
      var tkCard=null, tkReady=false, tkAmt=0, tkLabel='', tkVenueVal='', tkCityVal='', tkDateVal='', tkDoorsVal='', tkAddrVal='', tkEventIdVal='', tkQty=1;
      function tkQtyMax(){ var l=ticketLeft[tkEventIdVal]; var lim=(l!==undefined&&l!==null&&l>0)?Math.min(10,l):10; return Math.max(1,lim); }
      function tkUpdateTotal(){ var mx=tkQtyMax(); if(tkQty>mx) tkQty=mx; if(tkQty<1) tkQty=1; var vEl=document.getElementById('tkQtyVal'); if(vEl) vEl.textContent=tkQty; var tot=tkAmt*tkQty; var tEl=document.getElementById('tkTotal'); if(tEl) tEl.textContent=tkQty>1?('Total '+money(tot,CUR)+' for '+tkQty+' tickets'):''; var pb=document.getElementById('tkPayBtn'); if(pb&&sqCfg&&tkAmt>0) pb.textContent='Pay '+money(tot,CUR); var mns=document.getElementById('tkQtyMinus'), pls=document.getElementById('tkQtyPlus'); if(mns) mns.disabled=(tkQty<=1); if(pls) pls.disabled=(tkQty>=mx); }
      (function(){ var mns=document.getElementById('tkQtyMinus'), pls=document.getElementById('tkQtyPlus'); if(mns) mns.addEventListener('click',function(){ if(tkQty>1){ tkQty--; tkUpdateTotal(); } }); if(pls) pls.addEventListener('click',function(){ if(tkQty<tkQtyMax()){ tkQty++; tkUpdateTotal(); } }); })();
      async function initTicketCard(){ if(tkReady) return; var p=ensurePayments(); if(!p) return; try{ tkCard=await p.card(); await tkCard.attach('#card-container'); tkReady=true; }catch(e){ var s=document.getElementById('tkStatus'); if(s) s.textContent='Card form could not load.'; } }
      document.querySelectorAll('.ticket-btn').forEach(function(b){ b.addEventListener('click',function(){
        document.getElementById('tkVenue').textContent=b.getAttribute('data-venue')||'Show';
        document.getElementById('tkDate').textContent=b.getAttribute('data-date')||'';
        document.getElementById('tkCity').textContent=b.getAttribute('data-city')||'';
        tkLabel=b.getAttribute('data-venue')||'Show';
        tkVenueVal=tkLabel; tkCityVal=b.getAttribute('data-city')||''; tkDateVal=b.getAttribute('data-date')||''; tkDoorsVal=b.getAttribute('data-doors')||''; tkAddrVal=b.getAttribute('data-address')||'';
        document.getElementById('tkAddr').textContent=tkAddrVal;
        tkEventIdVal=b.getAttribute('data-event-id')||'';
        var _lv=ticketLeft[tkEventIdVal]; var _tl=document.getElementById('tkLeft'); if(_tl){ _tl.textContent=(_lv!==undefined&&_lv!==null&&_lv<=10&&_lv>0)?('Only '+_lv+' left'):''; }
        document.getElementById('tkForm').style.display=''; document.getElementById('tkDone').hidden=true; document.getElementById('tkPayBtn').style.display='';
        tkAmt=parseFloat(b.getAttribute('data-amount')||'')||0;
        var amtEl=document.getElementById('tkAmount'), payBtn=document.getElementById('tkPayBtn'), st=document.getElementById('tkStatus'), cardBox=document.getElementById('card-container');
        st.textContent='';
        var url=b.getAttribute('data-url')||'#', ext=document.getElementById('tkExternal');
        if(url&&url!=='#'){ ext.href=url; ext.style.display=''; } else { ext.style.display='none'; }
        openModal(ticketModal);
        if(sqCfg && tkAmt>0){ amtEl.textContent=money(tkAmt,CUR)+' per ticket'; tkQty=1; tkUpdateTotal(); payBtn.style.display=''; cardBox.style.display=''; payBtn.disabled=false; initTicketCard(); }
        else { amtEl.textContent=''; payBtn.style.display='none'; cardBox.style.display='none'; if(!sqCfg) st.textContent='Checkout is being switched on. Use the venue link below for now.'; }
      });});
      var tkPayBtn=document.getElementById('tkPayBtn');
      if(tkPayBtn){ tkPayBtn.addEventListener('click',async function(){
        if(!tkReady||!tkCard) return;
        var st=document.getElementById('tkStatus');
        var fn=(document.getElementById('tkFirst').value||'').trim();
        var ln=(document.getElementById('tkLast').value||'').trim();
        var em=(document.getElementById('tkEmail').value||'').trim();
        if(!fn||!ln||em.indexOf('@')<1){ st.textContent='Please add your first name, last name and email.'; return; }
        tkPayBtn.disabled=true; st.textContent='Processing...';
        try{
          var res=await tkCard.tokenize();
          if(res.status!=='OK'){ st.textContent=(res.errors&&res.errors[0]&&res.errors[0].message)?res.errors[0].message:'Please check your card details.'; tkPayBtn.disabled=false; return; }
          var r=await fetch('/api/pay',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sourceId:res.token, amount:Math.round(tkAmt*tkQty*100), currency:CUR, quantity:tkQty, note:'Tickets x'+tkQty+': '+tkLabel+' | '+fn+' '+ln, buyerEmail:em, buyerName:fn+' '+ln, kind:'ticket', event:{ venue:tkVenueVal, city:tkCityVal, date:tkDateVal, doors:tkDoorsVal, address:tkAddrVal, id:tkEventIdVal } }) });
          var data=await r.json();
          if(r.ok&&data.ok){ var num=data.ticketNo||''; var dn=document.getElementById('tkDoneNum'); if(dn) dn.textContent = num ? ('Ticket '+num) : ''; var dm=document.getElementById('tkDoneMsg'); if(dm) dm.textContent = data.emailed ? ('Check your email at '+em+' for your ticket'+(tkQty>1?'s':'')+'. See you on the floor.') : ('Your ticket number is '+num+'. See you on the floor.'); var tf=document.getElementById('tkForm'); if(tf) tf.style.display='none'; var td=document.getElementById('tkDone'); if(td) td.hidden=false; if(tkEventIdVal && data.left!==undefined && data.left!==null){ ticketLeft[tkEventIdVal]=data.left; renderShowLeft(tkEventIdVal); } }
          else { st.textContent=(data&&data.error)?data.error:'Payment failed. Please try again.'; if(data && typeof data.left!=='undefined' && data.left!==null && tkEventIdVal){ ticketLeft[tkEventIdVal]=data.left; renderShowLeft(tkEventIdVal); tkUpdateTotal(); } tkPayBtn.disabled=false; }
        }catch(e){ st.textContent='Something went wrong. Please try again.'; tkPayBtn.disabled=false; }
      }); }

      /* ---------- Store cart (merch) ---------- */
      var CART_KEY='modulrCart';
      var productModal=document.getElementById('productModal');
      var cartModal=document.getElementById('cartModal');
      var cart=[];
      try{ var _raw=localStorage.getItem(CART_KEY); if(_raw) cart=JSON.parse(_raw)||[]; }catch(e){ cart=[]; }
      if(!Array.isArray(cart)) cart=[];
      function cartSave(){ try{ localStorage.setItem(CART_KEY, JSON.stringify(cart)); }catch(e){} }
      function cartCount(){ var n=0; for(var i=0;i<cart.length;i++) n+=cart[i].qty; return n; }
      function cartSubtotalCents(){ var c=0; for(var i=0;i<cart.length;i++) c+=cart[i].unit*cart[i].qty; return c; }
      function slug(s){ return String(s||'').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,''); }

      var cartFab=document.getElementById('cartBtn'), cartFabCount=document.getElementById('cartBtnCount');
      function renderFab(){ var n=cartCount(); if(cartFabCount){ cartFabCount.textContent=n; cartFabCount.hidden=(n<=0); } }

      function cartAdd(product, size, qty, unit, image){
        qty=Math.max(1,Math.min(20,parseInt(qty,10)||1));
        var key=slug(product)+'|'+size;
        var found=null; for(var i=0;i<cart.length;i++){ if(cart[i].key===key){ found=cart[i]; break; } }
        if(found){ found.qty=Math.min(20, found.qty+qty); }
        else { cart.push({ key:key, product:product, size:size, qty:qty, unit:unit, image:image||'' }); }
        cartSave(); renderFab(); renderCart();
      }
      function cartSetQty(key, qty){ for(var i=0;i<cart.length;i++){ if(cart[i].key===key){ cart[i].qty=Math.max(1,Math.min(20,qty)); break; } } cartSave(); renderFab(); renderCart(); }
      function cartRemove(key){ cart=cart.filter(function(l){ return l.key!==key; }); cartSave(); renderFab(); renderCart(); }

      function renderCart(){
        var lines=document.getElementById('cartLines'); if(!lines) return;
        var empty=document.getElementById('cartEmpty'), summary=document.getElementById('cartSummary');
        var subEl=document.getElementById('cartSubtotal'), note=document.getElementById('cartNote'), coBtn=document.getElementById('cartCheckout');
        lines.innerHTML='';
        if(!cart.length){
          if(empty) empty.hidden=false; if(summary) summary.hidden=true; if(note) note.hidden=true; if(coBtn) coBtn.disabled=true;
        } else {
          if(empty) empty.hidden=true; if(summary) summary.hidden=false; if(note) note.hidden=false; if(coBtn) coBtn.disabled=false;
          cart.forEach(function(l){
            var row=document.createElement('div'); row.className='cart-line';
            var art=l.image?('<div class="cart-line-art"><img src="'+l.image+'" alt=""></div>'):'<div class="cart-line-art"></div>';
            row.innerHTML=art
              +'<div class="cart-line-main">'
              +  '<div class="cart-line-title"></div>'
              +  '<div class="cart-line-sub">Size '+l.size+'</div>'
              +  '<div class="cart-line-qty">'
              +    '<button type="button" class="tk-qty-btn cl-minus" aria-label="Fewer">&minus;</button>'
              +    '<span class="tk-qty-num cl-num">'+l.qty+'</span>'
              +    '<button type="button" class="tk-qty-btn cl-plus" aria-label="More">+</button>'
              +  '</div>'
              +'</div>'
              +'<div class="cart-line-end">'
              +  '<div class="cart-line-price">'+money(l.unit*l.qty/100,CUR)+'</div>'
              +  '<button type="button" class="cart-line-remove" aria-label="Remove">Remove</button>'
              +'</div>';
            row.querySelector('.cart-line-title').textContent=l.product;
            row.querySelector('.cl-minus').addEventListener('click',function(){ cartSetQty(l.key, l.qty-1); });
            row.querySelector('.cl-plus').addEventListener('click',function(){ cartSetQty(l.key, l.qty+1); });
            row.querySelector('.cart-line-remove').addEventListener('click',function(){ cartRemove(l.key); });
            lines.appendChild(row);
          });
        }
        if(subEl) subEl.textContent=money(cartSubtotalCents()/100,CUR);
        var pv=document.getElementById('pmView'); if(pv){ var n=cartCount(); pv.hidden=(n<=0); pv.textContent='View cart ('+n+') ›'; }
      }

      /* product modal: size + quantity + add to cart */
      var pmAdd=document.getElementById('pmAdd'), pmView=document.getElementById('pmView');
      var pmSize=null, pmAmt=0, pmName='', pmImage='', pmQty=1;
      function pmUpdateQty(){ if(pmQty<1) pmQty=1; if(pmQty>20) pmQty=20; var v=document.getElementById('pmQtyVal'); if(v) v.textContent=pmQty; var mn=document.getElementById('pmQtyMinus'), pl=document.getElementById('pmQtyPlus'); if(mn) mn.disabled=(pmQty<=1); if(pl) pl.disabled=(pmQty>=20); }
      (function(){ var mn=document.getElementById('pmQtyMinus'), pl=document.getElementById('pmQtyPlus'); if(mn) mn.addEventListener('click',function(){ if(pmQty>1){ pmQty--; pmUpdateQty(); } }); if(pl) pl.addEventListener('click',function(){ if(pmQty<20){ pmQty++; pmUpdateQty(); } }); })();
      function pmRefreshBtn(){ if(!(pmAmt>0)){ pmAdd.disabled=true; pmAdd.textContent='Coming soon'; return; } if(pmSize){ pmAdd.disabled=false; pmAdd.textContent='Add to cart'; } else { pmAdd.disabled=true; pmAdd.textContent='Select a size'; } }
      document.querySelectorAll('.buy-btn').forEach(function(b){ b.addEventListener('click',function(){
        pmName=b.getAttribute('data-name')||'Product';
        document.getElementById('pmName').textContent=pmName;
        pmAmt=parseFloat(b.getAttribute('data-price')||'')||0;
        document.getElementById('pmPrice').textContent=pmAmt>0?money(pmAmt,CUR):'Price on request';
        pmImage=b.getAttribute('data-image')||'';
        var img=document.getElementById('pmImg'); img.src=pmImage; img.alt=pmName;
        pmSize=null; pmQty=1; pmUpdateQty(); document.getElementById('pmStatus').textContent='';
        var sizes=[]; try{sizes=JSON.parse(b.getAttribute('data-sizes'));}catch(e){sizes=['S','M','L','XL','XXL'];}
        var box=document.getElementById('pmSizes'); box.innerHTML='';
        sizes.forEach(function(sz){ var el=document.createElement('button'); el.type='button'; el.className='size'; el.textContent=sz;
          el.addEventListener('click',function(){ box.querySelectorAll('.size').forEach(function(x){x.classList.remove('sel');}); el.classList.add('sel'); pmSize=sz; pmRefreshBtn(); });
          box.appendChild(el); });
        pmRefreshBtn(); renderCart(); openModal(productModal);
      });});
      if(pmAdd){ pmAdd.addEventListener('click',function(){
        if(!(pmAmt>0)) return;
        if(!pmSize){ document.getElementById('pmStatus').textContent='Please choose a size.'; return; }
        cartAdd(pmName, pmSize, pmQty, Math.round(pmAmt*100), pmImage);
        document.getElementById('pmStatus').textContent='Added to cart ✓';
        pmAdd.textContent='Added ✓'; pmAdd.disabled=true;
        setTimeout(function(){ pmRefreshBtn(); }, 900);
        pmQty=1; pmUpdateQty();
      }); }
      if(pmView){ pmView.addEventListener('click',function(){ closeModal(productModal); showCartView(); openModal(cartModal); renderCart(); }); }

      /* cart drawer + single checkout */
      if(cartFab){ cartFab.addEventListener('click',function(){ showCartView(); openModal(cartModal); renderCart(); }); }
      var cartView=document.getElementById('cartView'), checkoutView=document.getElementById('checkoutView'), cartDoneView=document.getElementById('cartDone');
      function showCartView(){ if(cartView) cartView.hidden=false; if(checkoutView) checkoutView.hidden=true; if(cartDoneView) cartDoneView.hidden=true; }
      function showCheckoutView(){ if(cartView) cartView.hidden=true; if(checkoutView) checkoutView.hidden=false; if(cartDoneView) cartDoneView.hidden=true; }

      var coCard=null, coReady=false;
      async function initCartCard(){ if(coReady) return; var p=ensurePayments(); if(!p) return; try{ coCard=await p.card(); await coCard.attach('#cart-card-container'); coReady=true; }catch(e){ var s=document.getElementById('coStatus'); if(s) s.textContent='Card form could not load.'; } }
      function renderCheckout(){
        var mini=document.getElementById('cartMini'); if(mini){ mini.innerHTML=''; cart.forEach(function(l){ var r=document.createElement('div'); r.className='cart-mini-row'; var a=document.createElement('span'); a.innerHTML='<em>Size '+l.size+'</em> ×'+l.qty; a.insertBefore(document.createTextNode(l.product+' '), a.firstChild); var bpr=document.createElement('span'); bpr.textContent=money(l.unit*l.qty/100,CUR); r.appendChild(a); r.appendChild(bpr); mini.appendChild(r); }); }
        var t=document.getElementById('coTotal'); if(t) t.textContent='Total '+money(cartSubtotalCents()/100,CUR);
        var pay=document.getElementById('coPay'); if(pay&&sqCfg) pay.textContent='Pay '+money(cartSubtotalCents()/100,CUR);
      }
      var cartCheckoutBtn=document.getElementById('cartCheckout');
      if(cartCheckoutBtn){ cartCheckoutBtn.addEventListener('click',function(){
        if(!cart.length) return;
        var cs=document.getElementById('coStatus'); if(cs) cs.textContent=''; var cp=document.getElementById('coPay'); if(cp) cp.disabled=false;
        showCheckoutView(); renderCheckout();
        if(sqCfg){ initCartCard(); } else if(cs){ cs.textContent='Checkout is being switched on. Please try again soon.'; }
      }); }
      var cartBackBtn=document.getElementById('cartBack');
      if(cartBackBtn){ cartBackBtn.addEventListener('click',function(){ showCartView(); renderCart(); }); }

      var coPay=document.getElementById('coPay');
      if(coPay){ coPay.addEventListener('click',async function(){
        if(!cart.length||!coReady||!coCard) return;
        var st=document.getElementById('coStatus');
        var fn=(document.getElementById('coFirst').value||'').trim();
        var ln=(document.getElementById('coLast').value||'').trim();
        var em=(document.getElementById('coEmail').value||'').trim();
        var ad=(document.getElementById('coAddr').value||'').trim();
        if(!fn||!ln||em.indexOf('@')<1||!ad){ st.textContent='Please add your name, email and shipping address.'; return; }
        coPay.disabled=true; st.textContent='Processing...';
        try{
          var res=await coCard.tokenize();
          if(res.status!=='OK'){ st.textContent=(res.errors&&res.errors[0]&&res.errors[0].message)?res.errors[0].message:'Please check your card details.'; coPay.disabled=false; return; }
          var items=cart.map(function(l){ return { product:l.product, size:l.size, qty:l.qty, unit:l.unit }; });
          var noteStr='Order: '+cart.map(function(l){ return l.product+' '+l.size+' x'+l.qty; }).join(', ')+' | '+fn+' '+ln+' | '+ad;
          var total=cartSubtotalCents();
          var r=await fetch('/api/pay',{ method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ sourceId:res.token, amount:total, currency:CUR, note:noteStr, buyerEmail:em, buyerName:fn+' '+ln, kind:'merch', item:{ address:ad }, items:items }) });
          var data=await r.json();
          if(r.ok&&data.ok){
            var num=data.orderNo||'';
            var dn=document.getElementById('cartDoneNum'); if(dn) dn.textContent = num ? ('Order '+num) : '';
            var dm=document.getElementById('cartDoneMsg'); if(dm) dm.textContent = data.emailed ? ('Check your email at '+em+' for your confirmation. The band will post your order to the address you gave.') : ('Your order number is '+num+'. The band will post it to your address.');
            cart=[]; cartSave(); renderFab();
            if(cartView) cartView.hidden=true; if(checkoutView) checkoutView.hidden=true; if(cartDoneView) cartDoneView.hidden=false;
          } else { st.textContent=(data&&data.error)?data.error:'Payment failed. Please try again.'; coPay.disabled=false; }
        }catch(e){ st.textContent='Something went wrong. Please try again.'; coPay.disabled=false; }
      }); }

      renderFab(); renderCart();
      function renderShowLeft(evId){
        var left=ticketLeft[evId];
        document.querySelectorAll('.ticket-btn[data-event-id="'+evId+'"]').forEach(function(b){
          var row=b.closest('.show-row'); if(!row) return;
          var ex=row.querySelector('.show-left');
          if(left!==null&&left!==undefined&&left<=0){ b.textContent='Sold Out'; b.disabled=true; b.classList.add('is-soldout'); if(ex) ex.remove(); }
          else if(left!==null&&left!==undefined&&left<=10){ if(!ex){ ex=document.createElement('span'); ex.className='show-left'; (row.querySelector('.show-venue-cell')||row).appendChild(ex); } ex.textContent='Only '+left+' left'; }
        });
      }
      document.querySelectorAll('.ticket-btn[data-event-id]').forEach(function(b){
        var evId=b.getAttribute('data-event-id'); if(!evId) return;
        fetch('/api/tickets?event='+encodeURIComponent(evId)).then(function(r){return r.json();}).then(function(d){
          if(!d||d.left===null||typeof d.left==='undefined') return;
          ticketLeft[evId]=d.left; renderShowLeft(evId);
        }).catch(function(){});
      });
    })();
  </script>
</body>
</html>
