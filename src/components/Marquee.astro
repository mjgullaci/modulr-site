---
import data from '../data/releases.json';
const titles = data.releases.map((r) => r.title);
const reps = [0, 1, 2, 3];
---
<div class="marquee t-light" data-theme="light" aria-hidden="true" data-screen-label="Marquee">
  <p class="marquee-line">
    <span class="mq">
      {reps.map(() => (
        <span class="mq-seg">
          <span class="mq-title">{titles.map((t, i) => (<span class={i === 0 ? 't on' : 't'}>{t}</span>))}</span>
          <span class="mq-dot">&bull;</span>
          <em>Out Now</em>
          <span class="mq-dot">&bull;</span>
        </span>
      ))}
    </span>
    <span class="mq">
      {reps.map(() => (
        <span class="mq-seg">
          <span class="mq-title">{titles.map((t, i) => (<span class={i === 0 ? 't on' : 't'}>{t}</span>))}</span>
          <span class="mq-dot">&bull;</span>
          <em>Out Now</em>
          <span class="mq-dot">&bull;</span>
        </span>
      ))}
    </span>
  </p>
</div>
