---
const mods = import.meta.glob('../content/releases/*.json', { eager: true });
const releases = Object.values(mods)
  .map((m) => m.default)
  .sort((a, b) => (a.order || 99) - (b.order || 99))
  .map((r) => ({
    ...r,
    links: [
      r.spotify && { label: 'Spotify', url: r.spotify },
      r.apple && { label: 'Apple', url: r.apple },
      r.bandcamp && { label: 'Bandcamp', url: r.bandcamp },
    ].filter(Boolean),
  }));
---
<section class="sec t-light" id="music" data-theme="light" data-screen-label="Music">
  <div class="wrap">
    <h2 class="sec-title">Music</h2>
    <div class="music-grid">
      {releases.map((r) => (
        <article class="tile">
          <div class="tile-art">
            {r.artwork ? <img src={r.artwork} alt={r.title + ' artwork'} /> : <span class="slot-ph">Artwork</span>}
          </div>
          <h3>{r.title}</h3>
          <p class="tile-meta">{r.kind} · {r.year}</p>
          <div class="tile-links">
            {r.links.map((l, i) => (
              <Fragment>
                {i > 0 && <span>·</span>}
                <a class="tlink" href={l.url} target="_blank" rel="noopener">{l.label}</a>
              </Fragment>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
